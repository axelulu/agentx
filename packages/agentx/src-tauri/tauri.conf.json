{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "AgentX",
  "version": "0.1.52",
  "identifier": "com.agentx.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm vite:dev",
    "beforeBuildCommand": "pnpm build:sidecar && pnpm vite:build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "AgentX",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https://*.openai.com https://*.anthropic.com https://*.googleapis.com https://*.openrouter.ai; img-src 'self' data: https: asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost; font-src 'self' data:"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "dmg", "app", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": [],
    "resources": {
      "../sidecar/dist/index.js": "sidecar/index.js",
      "../resources/toolkit/**/*": "toolkit/"
    },
    "macOS": {
      "entitlements": "../resources/entitlements.mac.plist",
      "minimumSystemVersion": "10.15",
      "frameworks": []
    },
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    },
    "linux": {
      "deb": {
        "section": "utils"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzNDUyODY4MDQ5Q0YwMzgKUldRNDhKd0VhQ2hGbzYvR0l5Q2UydjYwbmdsTnU5QzBKQ0JROG12MVpkZUYrVEtoOVFyVDl1QTUK",
      "endpoints": ["https://github.com/axelulu/agentx/releases/latest/download/latest.json"]
    }
  }
}
