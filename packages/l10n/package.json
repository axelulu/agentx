{
  "name": "@workspace/l10n",
  "version": "1.0.0",
  "private": true,
  "description": "Simple and powerful internationalization package for JavaScript/TypeScript applications",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./core": {
      "types": "./src/core.ts",
      "import": "./src/core.ts",
      "require": "./src/core.ts"
    },
    "./server-only": {
      "types": "./src/server-only.ts",
      "import": "./src/server-only.ts",
      "require": "./src/server-only.ts"
    },
    "./client-only": {
      "types": "./src/client-only.ts",
      "import": "./src/client-only.ts",
      "require": "./src/client-only.ts"
    },
    "./languages": {
      "types": "./src/languages.ts",
      "import": "./src/languages.ts",
      "require": "./src/languages.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "keywords": [
    "i18n",
    "l10n",
    "internationalization",
    "localization",
    "translation",
    "client",
    "frontend",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@workspace/eslint-config": "workspace:*",
    "eslint": "^9.20.1",
    "typescript": "^5.0.0",
    "vitest": "^4.0.5"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
