{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "AgentX",
  "version": "0.1.34",
  "identifier": "com.agentx.desktop",
  "build": {
    "frontendDist": "../dist-renderer",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm tauri:vite:dev",
    "beforeBuildCommand": "pnpm tauri:vite:build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "AgentX",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https://*.openai.com https://*.anthropic.com https://*.googleapis.com https://*.openrouter.ai; img-src 'self' data: https: asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost; font-src 'self' data:"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "externalBin": ["sidecar/agentx-sidecar"],
    "resources": {},
    "macOS": {
      "entitlements": "../resources/entitlements.mac.plist",
      "minimumSystemVersion": "10.15",
      "frameworks": []
    },
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    },
    "linux": {
      "deb": {
        "section": "utils"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": ["https://github.com/axelulu/agentx/releases/latest/download/latest.json"]
    }
  }
}
